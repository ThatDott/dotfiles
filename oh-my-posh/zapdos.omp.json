{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "root",
          "style": "plain",
          "foreground": "#FFD43B",
          "template": "󰞀 "
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "#FFD43B",
          "template": "🐍{{ .Venv }} "
        },
        {
          "foreground": "#ffffff",
          "properties": {
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
	{
	  "foreground": "#FFD43B",
	  "style": "plain",
          "template": "{{ .HEAD }} ",
          "type": "git"
        },
        {
          "foreground": "#FFD43B",
          "style": "plain",
          "template": "",
          "type": "text"
        },
        {
          "foreground": "#C94A16",
          "style": "plain",
          "template": "x{{ reason .Code }} ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#FFFFFF",
          "style": "plain",
          "template": "\ue602",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
